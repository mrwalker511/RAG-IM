# Database
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag_db

# Redis (task queue)
REDIS_URL=redis://localhost:6379

# Embeddings
EMBEDDING_PROVIDER=openai              # openai | sentence_transformer
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# LLM
LLM_PROVIDER=openai                    # openai | litellm
LLM_MODEL=gpt-4o-mini

# Chunking defaults (overridable per project via project config)
DEFAULT_CHUNK_SIZE=512
DEFAULT_CHUNK_OVERLAP=64
DEFAULT_TOP_K=5

# Retrieval
RERANK_TOP_N=20                        # Candidates passed to CrossEncoder
BM25_STALE_AFTER_MINUTES=60

# API
API_HOST=0.0.0.0
API_PORT=8000

# Security — restrict in production (comma-separated origins, or * for dev)
CORS_ORIGINS=*

# Rate limiting — requests per minute per API key (0 = disabled)
RATE_LIMIT_PER_MINUTE=60

# Database connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Redis connection pool
REDIS_MAX_CONNECTIONS=20

# Query result cache — seconds to cache responses in Redis (0 = disabled)
QUERY_CACHE_TTL=300
