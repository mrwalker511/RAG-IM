# Database
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5433/rag_db

# Redis (task queue)
REDIS_URL=redis://localhost:6379

# Embeddings (current local dev example)
EMBEDDING_PROVIDER=sentence_transformer  # openai | sentence_transformer
OPENAI_API_KEY=                          # optional unless using OpenAI provider
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# LLM (current local dev example)
LLM_PROVIDER=litellm                   # openai | litellm
LLM_MODEL=mistral/mistral-small-latest
# Example provider credential for the model above:
# MISTRAL_API_KEY=...

# Chunking defaults (overridable per project via project config)
DEFAULT_CHUNK_SIZE=512
DEFAULT_CHUNK_OVERLAP=64
DEFAULT_TOP_K=5

# Retrieval
RERANK_TOP_N=20                        # Candidates passed to CrossEncoder
BM25_STALE_AFTER_MINUTES=60

# API
API_HOST=0.0.0.0
API_PORT=8000
UPLOAD_TMP_DIR=/tmp

# Bootstrap management key. Set this before first boot, then use project-scoped
# keys for regular app traffic.
BOOTSTRAP_PROJECT_NAME=bootstrap
BOOTSTRAP_API_KEY=
BOOTSTRAP_API_KEY_LABEL=bootstrap

# Security — use explicit origins in staging/production
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting — requests per minute per API key (0 = disabled)
RATE_LIMIT_PER_MINUTE=60

# Database connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Redis connection pool
REDIS_MAX_CONNECTIONS=20

# Query result cache — seconds to cache responses in Redis (0 = disabled)
QUERY_CACHE_TTL=300

# Docker Compose overrides DATABASE_URL, REDIS_URL, and UPLOAD_TMP_DIR for
# the api/worker containers so they use the internal postgres/redis services
# and a shared upload temp directory.
